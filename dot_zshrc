# Lazygit with dir tracking
lg() {
  export LAZYGIT_NEW_DIR_FILE=~/.lazygit/newdir
  lazygit "$@"
  if [ -f $LAZYGIT_NEW_DIR_FILE ]; then
    cd "$(cat $LAZYGIT_NEW_DIR_FILE)"
    rm -f $LAZYGIT_NEW_DIR_FILE > /dev/null
  fi
}

# Prompt mise install for missing tools
function prompt_mise_install() {
  MISE_OUTPUT=$(mise ls --missing 2>&1)

  if echo "$MISE_OUTPUT" | grep -q "are not trusted"; then
    UNTRUSTED_CONFIG=$(echo "$MISE_OUTPUT" | grep -oP "(?<=Config files in ).*(?= are not trusted)" | head -1)
    print -P "${YELLOW}Untrusted mise config detected:${RESET}"
    print -P "${YELLOW}$UNTRUSTED_CONFIG${RESET}"
    print -nP "${BLUE}Would you like to trust this config? [y/N]: ${RESET}"
    read -r REPLY
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
      echo -P "${GREEN}Trusting config...${RESET}"
      mise trust
      MISE_OUTPUT=$(mise ls --missing 2>&1)
    else
      echo -P "${RED}Skipped trusting config.${RESET}"
      return
    fi
  fi

  MISSING_TOOLS=$(echo "$MISE_OUTPUT" | grep -v "ERROR" | grep -v "^$")

  if [[ -n "$MISSING_TOOLS" ]]; then
    print -P "${YELLOW}Missing tools detected:${RESET}"
    print -P "${YELLOW}$MISSING_TOOLS${RESET}"
    print -nP "${BLUE}Would you like to install dependencies? [y/N]: ${RESET}"
    read -r REPLY
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
      echo -P "${GREEN}Installing dependencies...${RESET}"
      mise install
    else
      echo -P "${RED}Skipped installing dependencies.${RESET}"
    fi
  fi
}

